    {
      "id": 15,
      "type": "table",
      "title": "Highest token usage conversations",
      "datasource": {
        "type": "tempo",
        "uid": "$tempo_ds"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "$tempo_ds"
          },
          "query": "{ name = \"pi.llm_request\" } | sum_over_time(span.gen_ai.usage.input_tokens) by (span.gen_ai.conversation.id)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "conversation_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open conversation in Tempo",
                    "url": "/explore?orgId=1&left={\"datasource\":\"${tempo_ds}\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceql\",\"query\":\"{ span.gen_ai.conversation.id = \\\"${__data.fields.conversation_id}\\\" }\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "conversation_id": 0,
              "Value": 1,
              "Time": 2
            },
            "renameByName": {
              "span.gen_ai.conversation.id": "conversation_id",
              "Value": "input_tokens"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "description": "Tempo TraceQL metrics fallback for grafana/otel-lgtm: input-token usage by conversation. Use the linked conversation id to inspect full trace details."
    }
  ],
