{
  "title": "pi-otel",
  "uid": "pi-otel",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["pi", "otel", "gen-ai"],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/min)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gen_ai_client_operation_duration_seconds_count{gen_ai_system=\"pi\"}[5m])) * 60",
          "legendFormat": "req/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Avg duration",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gen_ai_client_operation_duration_seconds_sum{gen_ai_system=\"pi\"}[5m])) / sum(rate(gen_ai_client_operation_duration_seconds_count{gen_ai_system=\"pi\"}[5m]))",
          "legendFormat": "avg",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total tokens/min",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gen_ai_client_token_usage_sum{gen_ai_system=\"pi\"}[5m])) * 60",
          "legendFormat": "tokens/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg tool calls/operation",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gen_ai_client_tool_calls_per_operation_sum{gen_ai_system=\"pi\"}[5m])) / sum(rate(gen_ai_client_tool_calls_per_operation_count{gen_ai_system=\"pi\"}[5m]))",
          "legendFormat": "avg tool calls",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Operation duration percentiles",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_system=\"pi\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_system=\"pi\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_system=\"pi\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token usage by type",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gen_ai_client_token_usage_sum{gen_ai_system=\"pi\"}[5m])) by (gen_ai_token_type) * 60",
          "legendFormat": "{{gen_ai_token_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Duration by model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_system=\"pi\"}[5m])) by (le, gen_ai_response_model))",
          "legendFormat": "p95 {{gen_ai_response_model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Tool calls per operation",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(gen_ai_client_tool_calls_per_operation_bucket{gen_ai_system=\"pi\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_tool_calls_per_operation_bucket{gen_ai_system=\"pi\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    }
  ]
}
